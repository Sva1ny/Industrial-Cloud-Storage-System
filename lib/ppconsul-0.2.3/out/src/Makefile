	cd /Users/lee1y/Desktop/CloudDisk_v5/lib/ppconsul-0.2.3/out && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
